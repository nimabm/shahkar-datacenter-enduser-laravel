{
    "name": "shahkar/datacenter",
    "description": "Laravel package for Shahkar End-User Data Center API integration",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "shahkar", "datacenter", "api"],
    "authors": [
        {
            "name": "Nima Barzegar",
            "email": "nima@barzegar.eu"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-mbstring": "*",
        "laravel/framework": "^10.0|^11.0",
        "guzzlehttp/guzzle": "^7.0",
        "web-token/jwt-library": "^3.4",
        "spomky-labs/aes-key-wrap": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Shahkar\\DataCenter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Shahkar\\DataCenter\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Shahkar\\DataCenter\\ShahkarDataCenterServiceProvider"
            ],
            "aliases": {
                "ShahkarDataCenter": "Shahkar\\DataCenter\\Facades\\ShahkarDataCenter"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
